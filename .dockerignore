.git
.gitignore
.venv
.pytest_cache
.ruff_cache
.mypy_cache
__pycache__
*.pyc

# Local-only artefacts (regenerated by the demo at runtime).
var/*
!var/.gitkeep
sandbox/effects/*
!sandbox/effects/.gitkeep

# Build output / docs that the runtime image does not need.
dist
build
htmlcov
.coverage
docs

# Local Claude config (never ship)
CLAUDE.md
.claude

# Source artefacts
SHA256SUMS.txt
mcp-http-streaming-demo-prompt-pack/
*.zip

# Tests are not required at runtime; only fixtures are.
tests/integration
tests/security
tests/unit
