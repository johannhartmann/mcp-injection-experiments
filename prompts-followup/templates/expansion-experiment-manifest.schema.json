{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MCP Exploit Expansion Experiment Manifest",
  "type": "object",
  "required": [
    "id",
    "title",
    "phase",
    "mcp_surfaces",
    "safe_impact",
    "modes",
    "references"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "phase": {
      "type": "string",
      "const": "expansion-2025-2026"
    },
    "owasp": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "agent_traps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mcp_surfaces": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requires_network": {
      "type": "boolean",
      "const": false
    },
    "uses_real_secrets": {
      "type": "boolean",
      "const": false
    },
    "uses_real_third_party_apis": {
      "type": "boolean",
      "const": false
    },
    "safe_impact": {
      "type": "object",
      "required": [
        "vulnerable_artifacts",
        "defended_artifacts",
        "reset_required"
      ],
      "properties": {
        "vulnerable_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "defended_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reset_required": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "modes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "vulnerable",
          "defended"
        ]
      },
      "contains": {
        "const": "vulnerable"
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
